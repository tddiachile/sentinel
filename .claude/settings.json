{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-3-7-sonnet-20250219",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "MAX_MCP_OUTPUT_TOKENS": "15000"
  },
  "permissions": {
    "allow": [
      "Bash(go test *)",
      "Bash(go fmt *)",
      "Bash(go build *)",
      "Bash(docker-compose *)",
      "Bash(tmux *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./keys/*.pem)",
      "Write(./keys/*.pem)",
      "Bash(rm -rf migrations/)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "go fmt ./...",
            "statusMessage": "Optimizando código Go..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_HOOK_INPUT\" | grep -q \"rm \"; then exit 2; fi",
            "statusMessage": "Protegiendo sistema de archivos..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "go test ./internal/domain/... -short",
            "statusMessage": "Validando lógica de Sentinel..."
          }
        ]
      }
    ]
  }
}
