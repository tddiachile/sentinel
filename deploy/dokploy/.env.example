# =============================================================================
# Sentinel — Variables de entorno para Dokploy
# Copiar el contenido en la pestaña "Environment" del compose en Dokploy.
# NUNCA subir este archivo con valores reales al repositorio.
# =============================================================================

# ---- Dominio público (Traefik) ----
DOMAIN=sentinel.tudominio.com

# ---- PostgreSQL ----
DB_NAME=sentinel
DB_USER=sentinel
DB_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ---- Redis ----
# Contraseña obligatoria en producción
REDIS_PASSWORD=CAMBIAR_POR_CONTRASENA_REDIS

# ---- Bootstrap (solo primer arranque) ----
# El administrador deberá cambiar esta contraseña en el primer login.
# No se valida la política de contraseñas en el bootstrap.
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_BOOTSTRAP

# ---- Frontend (build-time args) ----
# VITE_API_URL: no cambiar — Nginx proxía /api/* al backend internamente.
VITE_API_URL=/api/v1
# VITE_APP_KEY: obtener del primer despliegue.
# Ver paso 5 del README: docker compose logs auth-service | grep secret_key
VITE_APP_KEY=OBTENER_DEL_PRIMER_DEPLOY
