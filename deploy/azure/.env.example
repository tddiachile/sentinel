# =============================================================================
# Sentinel — Variables para despliegue en Azure
# Exportar antes de ejecutar los comandos az CLI del README.
# =============================================================================

# ---- Suscripción y grupo de recursos ----
AZURE_SUBSCRIPTION_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_RESOURCE_GROUP=rg-sentinel
AZURE_LOCATION=eastus

# ---- Azure Container Registry ----
ACR_NAME=mysentinelacr
ACR_LOGIN_SERVER=mysentinelacr.azurecr.io

# ---- Imagen tags ----
AUTH_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ---- Base de datos ----
DB_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ---- Bootstrap ----
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_BOOTSTRAP

# ---- Frontend ----
# Obtener del primer despliegue (logs del auth-service)
VITE_APP_KEY=OBTENER_DEL_PRIMER_DEPLOY

# ---- Dominio personalizado (opcional) ----
CUSTOM_DOMAIN=sentinel.tudominio.com
