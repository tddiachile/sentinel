# =============================================================================
# Sentinel — Variables de entorno para DigitalOcean Droplet
# Copiar como: cp .env.example .env  y rellenar los valores reales.
# Colocar el archivo .env en: deploy/digitalocean/.env
# =============================================================================

# ---- Dominio y SSL (Let's Encrypt) ----
DOMAIN=sentinel.tudominio.com
ACME_EMAIL=admin@tudominio.com     # Email para avisos de Let's Encrypt

# ---- PostgreSQL ----
DB_NAME=sentinel
DB_USER=sentinel
DB_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ---- Redis ----
REDIS_PASSWORD=CAMBIAR_POR_CONTRASENA_REDIS

# ---- Bootstrap (primer arranque) ----
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_BOOTSTRAP

# ---- Container Registry (DOCR) ----
# URL del registry: registry.digitalocean.com/<TU_ORG>
REGISTRY=registry.digitalocean.com/TU_ORG
# Tag de las imágenes a desplegar (ej: latest, v1.0, v1.1)
IMAGE_TAG=latest
